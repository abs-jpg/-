# Default ignored files
/shelf/
/workspace.xml
# Ignored default folder with query files
/queries/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml
# Editor-based HTTP Client requests
/httpRequests/
# =========================
# 通用配置 (系统与编辑器)
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.log

# =========================
# 前端 (JavaScript/Web)
# =========================
# 依赖包
node_modules/

# 构建输出目录 (根据你的打包工具可能有所不同)
dist/
build/
out/
.next/
.nuxt/

# 环境变量 (绝不要将生产环境的敏感 key 提交到 Git)
.env
.env.local
.env.development
.env.test
.env.production

# 包管理器日志与缓存
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# =========================
# 后端 (Python/大模型)
# =========================
# 编译后的字节码
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境 (非常重要)
venv/
.venv/
env/
.env/

# Jupyter Notebook 缓存 (如果你用它做数据探索)
.ipynb_checkpoints/

# =========================
# 大模型专属 (权重、缓存与数据)
# =========================
# 模型权重文件 (避免提交几GB甚至几十GB的大文件)
*.pt
*.pth
*.bin
*.ckpt
*.safetensors
*.gguf
*.onnx

# 常见的模型下载与缓存目录
models/
huggingface/
.cache/

# 训练相关的日志、检查点与数据集
data/
datasets/
runs/
checkpoints/
wandb/

# 向量数据库本地持久化文件 (如果用到了RAG检索增强生成)
chroma/
faiss_index/
milvus_data/# =========================
